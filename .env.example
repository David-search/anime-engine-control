# Control-plane secrets for AniChan (anime-engine-control). Copy this
# file to .env (gitignored) and fill in real values. NEVER commit .env,
# and NEVER paste the real Mongo/ES passwords here — keep the literal
# placeholder "<stored in control .env on the server>". The push
# auto-classifier blocks commits that contain the real password.

# ── GitHub ──────────────────────────────────────────────────────
# Token used by /work-on (clone) and /deploy-* (commit + push).
# Required scopes:
#   - classic PAT: `repo` for source pushes, plus `workflow` if you'll
#     edit `.github/workflows/*` (control repo does NOT touch workflows
#     once they're shipped).
#   - fine-grained PAT: Contents:read+write, Metadata:read,
#     Workflows:read+write (only if editing workflows). Scope to the
#     David-search org's anime-engine-{frontend,backend,control} repos.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USER=David-search                          # used by git-credential-store
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# ── SSH to deploy server (vast-canada-2) ────────────────────────
# Single host. These work from any machine. From on the server itself
# the slash commands that wrap `ssh` still work (they loop back), but
# you can also just run the inner command directly.
SSH_HOST=70.30.158.46
SSH_PORT=43730
SSH_USER=root
SSH_KEY=~/.ssh/id_rsa                              # path to your private key on THIS machine

# ── Data stores ─────────────────────────────────────────────────
# Shared host, AniChan-owned db/index. Reachable off-server via the
# external ports below; on-server use the container names mongodb:27017
# and elasticsearch:9200 on the goongle-network instead.
MONGO_URI=mongodb://admin:<stored in control .env on the server>@70.30.158.46:43829/anime_db?authSource=admin

ELASTIC_URL=http://70.30.158.46:43505
ELASTIC_USER=elastic
ELASTIC_PASSWORD=<stored in control .env on the server>
ELASTIC_INDEX=anime

# ── Public service URLs (off-server) ────────────────────────────
FRONTEND_URL=http://70.30.158.46:43879
BACKEND_URL=http://70.30.158.46:43577

# ── Auth ────────────────────────────────────────────────────────
# Google OAuth client id for sign-in (email + Google). Leave blank
# until the OAuth consent screen / client is provisioned.
GOOGLE_CLIENT_ID=

# ── Source repos (cloned on demand by /work-on and /deploy-*) ───
REPO_FRONTEND=https://github.com/David-search/anime-engine-frontend.git
REPO_BACKEND=https://github.com/David-search/anime-engine-backend.git
