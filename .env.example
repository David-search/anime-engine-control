# Control-plane secrets for AniChan (anime-engine-control). Copy this
# file to .env (gitignored) and fill in real values. NEVER commit .env,
# and NEVER paste the real Mongo/ES/Eweka/offshore passwords here — keep
# the literal placeholder "<stored in control .env>". The push
# auto-classifier blocks commits that contain the real password.
#
# This .env is the SINGLE entrypoint for every credential: app stack,
# data stores, AND the self-host video build farm. Full ops detail for
# the build farm lives in self-hosted/RUNBOOK.md.

# ── GitHub ──────────────────────────────────────────────────────
# Token used by /work-on (clone) and /deploy-* (commit + push).
# Required scopes: classic PAT `repo` (+`workflow` only if editing
# .github/workflows). Scope to David-search org's
# anime-engine-{frontend,backend,control} repos.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USER=David-search                          # used by git-credential-store
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# ── SSH to deploy/app server (vast-canada-2) ────────────────────
SSH_HOST=70.30.158.46
SSH_PORT=43730
SSH_USER=root
SSH_KEY=~/.ssh/id_rsa                              # path to your private key on THIS machine

# ── Public edge (web-goongle) — nginx TLS reverse proxy for anichan.net ──
# anichan.net is served HERE, not by canada-2 directly: nginx terminates TLS
# (Let's Encrypt) and reverse-proxies to canada-2 (/ -> :43879 Next.js,
# /api/ + /api/watch/ -> :43577 FastAPI). SHARED host — also serves goongle.net;
# only ever touch the anichan.net vhost. See .claude/guides/infrastructure.md.
EDGE_HOST=66.55.65.89                              # ssh alias: web-goongle
EDGE_USER=root
EDGE_PASSWORD=<stored in control .env>            # password auth only (no key yet)
EDGE_DOMAIN=anichan.net
EDGE_VHOST=/etc/nginx/sites-enabled/anichan.net

# ── Data stores (shared host, AniChan-owned db/index) ───────────
MONGO_URI=mongodb://admin:<stored in control .env>@70.30.158.46:43829/anime_db?authSource=admin

ELASTIC_URL=http://70.30.158.46:43505
ELASTIC_USER=elastic
ELASTIC_PASSWORD=<stored in control .env>
ELASTIC_INDEX=anime

# ── Public service URLs (off-server) ────────────────────────────
FRONTEND_URL=http://70.30.158.46:43879
BACKEND_URL=http://70.30.158.46:43577

GOOGLE_CLIENT_ID=

# ── Source repos (cloned on demand by /work-on and /deploy-*) ───
REPO_FRONTEND=https://github.com/David-search/anime-engine-frontend.git
REPO_BACKEND=https://github.com/David-search/anime-engine-backend.git

# ════════════════════════════════════════════════════════════════
#  SELF-HOST VIDEO PIPELINE  (offshore HLS origin + 6-node build farm)
#  Full ops detail: self-hosted/RUNBOOK.md
# ════════════════════════════════════════════════════════════════

# ── Backend self-host wiring (also set in /home/anime/backend/.env) ─
SELFHOST_ORIGIN=http://185.255.120.59             # backend live-probes + proxies this HLS origin
SELFHOST_CACHE=1
SELFHOST_INGEST_TOKEN=<stored in control .env>    # gates POST /api/watch/cache-state (coverage marks)

# ── Offshore HLS origin (DMCA-ignored video host, ~17 TB) ───────
OFFSHORE_HOST=185.255.120.59
OFFSHORE_USER=root
OFFSHORE_PASSWORD=<stored in control .env>        # rotate + disable password auth (nodes ship via ssh key)
OFFSHORE_HLS_DIR=/srv/hls
OFFSHORE_CAP_TB=16

# ── Eweka Usenet — 3 accounts, 2 build nodes each ───────────────
# HARD LIMIT/account: ~20 connections AND max 2 simultaneous source IPs.
# => 2 nodes/account (2 distinct egress IPs), 8 connections/node.
EWEKA_HOST=news.eweka.nl
EWEKA_PORT=563
EWEKA1_USER=<eweka acct1 username>                # acct1 -> canada-3 + canada-4
EWEKA1_PASS=<stored in control .env>
EWEKA2_USER=<eweka acct2 username>                # acct2 -> canada-5 + canada-6
EWEKA2_PASS=<stored in control .env>
EWEKA3_USER=<eweka acct3 username>                # acct3 -> canada-2 + canada-7
EWEKA3_PASS=<stored in control .env>

# ── NZBGet control (per build node, localhost XML-RPC) ──────────
NZBGET_CONTROL_PORT=6789
NZBGET_CONTROL_USER=nzbget
NZBGET_CONTROL_PASS=<stored in control .env>

# ── Build farm nodes (vast.ai; ssh aliases in ~/.ssh/config) ────
# 6 build nodes = canada-2..7 (canada-1 = goongle-prod, NOT used).
# host:port  # account, GPU.  Real values in .env (these rotate as you
# rent/kill instances — keep ~/.ssh/config in sync).
NODE_CANADA2=<host:port>                           # acct3 | RTX 4060 Ti | also the app/prod host
NODE_CANADA3=<host:port>                           # acct1 | RTX A4000
NODE_CANADA4=<host:port>                           # acct1 | RTX 4060 Ti
NODE_CANADA5=<host:port>                           # acct2 | RTX 2060
NODE_CANADA6=<host:port>                           # acct2 | RTX 4070 Ti
NODE_CANADA7=<host:port>                           # acct3 | GTX 1070 Ti
